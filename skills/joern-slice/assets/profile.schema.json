{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rekit.dev/schemas/joern-behavior-profile-v1.json",
  "title": "Rekit Joern behavior profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "sources", "sinks"],
  "properties": {
    "schemaVersion": {"const": 1},
    "id": {"type": "string", "minLength": 1},
    "findingKind": {"type": "string", "minLength": 1},
    "sources": {"$ref": "#/$defs/patterns"},
    "sinks": {"$ref": "#/$defs/patterns"}
  },
  "$defs": {
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "pattern"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "pattern": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
