# Locally built skill runtimes are rebuildable from committed manifests and lockfiles.
skills/*/scripts/node_modules/
skills/*/scripts/site/

# Private or locally built native payloads: usable in-place, never redistributed.
skills/dex-dump/bin/dex-dumper
skills/pyscylla/bin/

# Python / OS / tooling
__pycache__/
*.py[cod]
.DS_Store
.mypy_cache/
.ruff_cache/
